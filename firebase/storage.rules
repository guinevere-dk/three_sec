rules_version = '2';

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔐 Firebase Storage 보안 규칙 (3s Vlog App)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
// 핵심 원칙:
// 1. 인증된 사용자만 접근 가능
// 2. 자신의 영상에만 접근 가능 (uid 기반)
// 3. Standard 등급 이상만 업로드 가능 (Firestore 검증)
// 4. 용량 제한 준수 (Standard: 50GB, Premium: 200GB)
// 5. 영상 파일만 업로드 가능 (mp4, mov 등)

service firebase.storage {
  match /b/{bucket}/o {
    
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 📹 사용자 영상 경로: users/{userId}/videos/{videoId}/{fileName}
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    match /users/{userId}/videos/{videoId}/{fileName} {
      
      // ✅ 읽기 권한: 인증된 본인만 가능
      allow read: if request.auth != null 
                  && request.auth.uid == userId;
      
      // ✅ 최소 안전 원복:
      // - 인증된 본인(uid 일치)
      // - 영상 파일 타입/크기 검증
      // 참고: 등급/용량 검증은 앱/Firestore 경로에서 관리
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && isValidVideoFile();
      
      // ✅ 삭제 권한: 인증된 본인만 가능
      allow delete: if request.auth != null 
                    && request.auth.uid == userId;
    }

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 👤 사용자 프로필 이미지 경로: users/{userId}/profile/{fileName}
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    match /users/{userId}/profile/{fileName} {

      // ✅ 읽기 권한: 인증된 본인만 가능
      allow read: if request.auth != null
                  && request.auth.uid == userId;

      // ✅ 쓰기 권한: 인증된 본인 + 이미지 파일 검증
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && isValidProfileImageFile();

      // ✅ 삭제 권한: 인증된 본인만 가능
      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }
    
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // 🛡️ 보안 함수
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    /// 유효한 영상 파일 확인
    /// - 크기: 최대 500MB
    /// - 타입: video/mp4, video/quicktime (mov), video/x-msvideo (avi)
    function isValidVideoFile() {
      let maxSize = 500 * 1024 * 1024; // 500MB
      let validTypes = ['video/mp4', 'video/quicktime', 'video/x-msvideo', 'video/mpeg'];
      
      return request.resource.size <= maxSize
          && request.resource.contentType in validTypes;
    }

    /// 유효한 프로필 이미지 파일 확인
    /// - 크기: 최대 10MB
    /// - 타입: image/jpeg, image/png, image/webp
    function isValidProfileImageFile() {
      let maxSize = 10 * 1024 * 1024; // 10MB
      let validTypes = ['image/jpeg', 'image/png', 'image/webp'];

      return request.resource.size <= maxSize
          && request.resource.contentType in validTypes;
    }
    
  }
}
